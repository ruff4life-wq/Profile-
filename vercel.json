{
  "version": 2,
  "builds": [
    {
      "src": "server.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/Marvin-Ruff-Profile.pdf",
      "dest": "/public/Marvin-Ruff-Profile.pdf"
    },
    {
      "src": "/profile.jpg",
      "dest": "/public/profile.jpg"
    },
    {
      "src": "/api/(.*)",
      "dest": "/server.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/server.ts"
    }
  ]
}