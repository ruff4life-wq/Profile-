{
  "version": 2,
  "cleanUrls": true,
  "routes": [
    {
      "src": "/profile.jpg",
      "dest": "/public/profile.jpg"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/api/(.*)",
      "dest": "/server.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/server.ts"
    }
  ]
}
